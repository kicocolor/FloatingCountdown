{
  "name": "floating-countdown",
  "version": "1.0.0",
  "description": "A simple floating countdown timer for Windows and macOS.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package:mac": "node scripts/package-macos.js",
    "package:mac:arm64": "node scripts/package-macos.js --arm64",
    "package:mac:x64": "node scripts/package-macos.js --x64",
    "package:win:x64": "node scripts/package-windows.js --x64",
    "package:win": "node scripts/package-windows.js",
    "package:win:arm64": "node scripts/package-windows.js --arm64"
  },
  "keywords": [
    "electron",
    "countdown",
    "timer",
    "floating"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-packager": "^17.1.2"
  }
}
